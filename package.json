{
  "name": "tokenforge",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-chain token launcher dApp",
  "homepage": "https://github.com/Unwrenchable/cookbook#readme",
  "bugs": {
    "url": "https://github.com/Unwrenchable/cookbook/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Unwrenchable/cookbook.git"
  },
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "contracts/evm",
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "compile": "turbo run compile",
    "lint": "turbo run lint",
    "clean": "turbo run clean --parallel"
  },
  "devDependencies": {
    "turbo": "^2.9.4"
  },
  "overrides": {
    "axios": "^1.15.0",
    "defu": "^6.1.5",
    "flatted": "^3.4.2",
    "h3": "^1.15.11",
    "hono": "4.12.12",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "picomatch": "^2.3.2",
    "serialize-javascript": "^7.0.5",
    "socket.io-parser": "^4.2.6"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "bs58": "^6.0.0",
      "@solana/sysvars": "^5.0.0",
      "hono": "4.12.12",
      "axios": "^1.15.0",
      "lodash": "^4.18.1",
      "serialize-javascript": "^7.0.5"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ],
      "allowAny": [
        "react",
        "react-dom"
      ]
    }
  }
}