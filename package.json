{
  "name": "tokenforge",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-chain token launcher dApp",
  "homepage": "https://github.com/Unwrenchable/cookbook#readme",
  "bugs": {
    "url": "https://github.com/Unwrenchable/cookbook/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Unwrenchable/cookbook.git"
  },
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "contracts/evm",
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "compile": "turbo run compile",
    "lint": "turbo run lint",
    "clean": "turbo run clean --parallel"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "bs58": "^6.0.0",
      "@solana/sysvars": "^2.1.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ],
      "allowAny": [
        "react",
        "react-dom"
      ]
    }
  }
}