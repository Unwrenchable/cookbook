{
  "name": "@tokenforge/contracts-evm",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:bscTestnet": "hardhat run scripts/deploy.ts --network bscTestnet",
    "deploy:polygonMumbai": "hardhat run scripts/deploy.ts --network polygonMumbai",
    "deploy:arbitrumSepolia": "hardhat run scripts/deploy.ts --network arbitrumSepolia",
    "deploy:baseSepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network mainnet",
    "deploy:bsc": "hardhat run scripts/deploy.ts --network bsc",
    "deploy:polygon": "hardhat run scripts/deploy.ts --network polygon",
    "deploy:arbitrum": "hardhat run scripts/deploy.ts --network arbitrum",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:avalanche": "hardhat run scripts/deploy.ts --network avalanche",
    "clean": "hardhat clean",
    "lint": "solhint 'contracts/**/*.sol'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "hardhat": "^2.22.0",
    "solhint": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "dotenv": "^17.3.1"
  }
}
