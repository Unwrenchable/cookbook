{
  "version": "0.1.0",
  "name": "token_burn_bridge",
  "instructions": [
    {
      "name": "initialize",
      "docs": ["Called once by the deployer to configure the bridge."],
      "accounts": [
        {
          "name": "config",
          "isMut": true,
          "isSigner": false,
          "docs": ["Bridge config PDA (seeds: [\"bridge-config\"])"]
        },
        {
          "name": "tokenMint",
          "isMut": false,
          "isSigner": false,
          "docs": ["The SPL token mint that will be burned"]
        },
        {
          "name": "authority",
          "isMut": true,
          "isSigner": true,
          "docs": ["Payer and authority over the bridge config"]
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "evmReceiverAddresses",
          "type": {
            "vec": {
              "defined": "EvmChainReceiver"
            }
          }
        }
      ]
    },
    {
      "name": "burnAndBridge",
      "docs": [
        "Burns SPL tokens and emits a Wormhole cross-chain message to activate",
        "ERC20 minting on one or more EVM chains."
      ],
      "accounts": [
        {
          "name": "config",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "tokenMint",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "userTokenAccount",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "userNonce",
          "isMut": true,
          "isSigner": false,
          "docs": ["Per-user nonce PDA for replay protection (seeds: [\"user-nonce\", user])"]
        },
        {
          "name": "user",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "tokenProgram",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "amount",
          "type": "u64"
        },
        {
          "name": "targetChainId",
          "type": "u16"
        },
        {
          "name": "evmRecipient",
          "type": {
            "array": ["u8", 20]
          }
        },
        {
          "name": "consistencyLevel",
          "type": "u8"
        }
      ]
    },
    {
      "name": "updateReceivers",
      "docs": ["Update the list of EVM chain receivers (only authority)."],
      "accounts": [
        {
          "name": "config",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "authority",
          "isMut": false,
          "isSigner": true
        }
      ],
      "args": [
        {
          "name": "evmReceivers",
          "type": {
            "vec": {
              "defined": "EvmChainReceiver"
            }
          }
        }
      ]
    }
  ],
  "accounts": [
    {
      "name": "BridgeConfig",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority",         "type": "publicKey" },
          { "name": "tokenMint",         "type": "publicKey" },
          { "name": "evmReceivers",      "type": { "vec": { "defined": "EvmChainReceiver" } } },
          { "name": "totalBurned",       "type": "u64" },
          { "name": "totalMessagesSent", "type": "u64" },
          { "name": "bump",              "type": "u8" }
        ]
      }
    },
    {
      "name": "UserNonce",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "nonce", "type": "u64" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "EvmChainReceiver",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "chainId",         "type": "u16" },
          { "name": "receiverAddress", "type": { "array": ["u8", 20] } },
          { "name": "isActive",        "type": "bool" }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "BurnMessageEmitted",
      "fields": [
        { "name": "sequence",         "type": "u64",                   "index": false },
        { "name": "solanaMint",       "type": "publicKey",             "index": false },
        { "name": "solanaSender",     "type": "publicKey",             "index": false },
        { "name": "evmRecipient",     "type": { "array": ["u8", 20] }, "index": false },
        { "name": "amountBurned",     "type": "u64",                   "index": false },
        { "name": "targetChainId",    "type": "u16",                   "index": false },
        { "name": "payloadHash",      "type": { "array": ["u8", 32] }, "index": false },
        { "name": "consistencyLevel", "type": "u8",                    "index": false }
      ]
    }
  ],
  "errors": [
    { "code": 6000, "name": "BurnTooSmall",       "msg": "Burn amount too small. Minimum is 100 tokens to activate 1 chain." },
    { "code": 6001, "name": "InsufficientBalance", "msg": "Insufficient token balance." },
    { "code": 6002, "name": "UnsupportedChain",    "msg": "Target chain not supported. Add it via update_receivers." },
    { "code": 6003, "name": "WrongMint",           "msg": "Token mint does not match bridge config." },
    { "code": 6004, "name": "WrongOwner",          "msg": "Token account owner does not match signer." },
    { "code": 6005, "name": "Unauthorized",        "msg": "Unauthorized: only the bridge authority can call this." },
    { "code": 6006, "name": "TooManyReceivers",    "msg": "Too many EVM receivers. Maximum is 10." }
  ],
  "metadata": {
    "address": "11111111111111111111111111111111"
  }
}
