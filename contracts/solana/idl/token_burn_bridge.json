{
  "address": "11111111111111111111111111111111",
  "metadata": {
    "name": "token_burn_bridge",
    "version": "0.1.0",
    "spec": "0.1.0"
  },
  "instructions": [
    {
      "name": "initialize",
      "discriminator": [175, 175, 109, 31, 13, 152, 155, 237],
      "docs": ["Called once by the deployer to configure the bridge."],
      "accounts": [
        {
          "name": "config",
          "writable": true,
          "docs": ["Bridge config PDA (seeds: [\"bridge-config\"])"]
        },
        {
          "name": "tokenMint",
          "docs": ["The SPL token mint that will be burned"]
        },
        {
          "name": "authority",
          "writable": true,
          "signer": true,
          "docs": ["Payer and authority over the bridge config"]
        },
        {
          "name": "systemProgram"
        }
      ],
      "args": [
        {
          "name": "evmReceiverAddresses",
          "type": {
            "vec": {
              "defined": {
                "name": "EvmChainReceiver"
              }
            }
          }
        }
      ]
    },
    {
      "name": "burnAndBridge",
      "discriminator": [187, 9, 252, 183, 112, 230, 84, 14],
      "docs": [
        "Burns SPL tokens and emits a Wormhole cross-chain message to activate",
        "ERC20 minting on one or more EVM chains."
      ],
      "accounts": [
        {
          "name": "config",
          "writable": true
        },
        {
          "name": "tokenMint",
          "writable": true
        },
        {
          "name": "userTokenAccount",
          "writable": true
        },
        {
          "name": "userNonce",
          "writable": true,
          "docs": ["Per-user nonce PDA for replay protection (seeds: [\"user-nonce\", user])"]
        },
        {
          "name": "user",
          "writable": true,
          "signer": true
        },
        {
          "name": "tokenProgram"
        },
        {
          "name": "systemProgram"
        }
      ],
      "args": [
        {
          "name": "amount",
          "type": "u64"
        },
        {
          "name": "targetChainId",
          "type": "u16"
        },
        {
          "name": "evmRecipient",
          "type": {
            "array": ["u8", 20]
          }
        },
        {
          "name": "consistencyLevel",
          "type": "u8"
        }
      ]
    },
    {
      "name": "updateReceivers",
      "discriminator": [93, 113, 76, 123, 168, 158, 158, 229],
      "docs": ["Update the list of EVM chain receivers (only authority)."],
      "accounts": [
        {
          "name": "config",
          "writable": true
        },
        {
          "name": "authority",
          "signer": true
        }
      ],
      "args": [
        {
          "name": "evmReceivers",
          "type": {
            "vec": {
              "defined": {
                "name": "EvmChainReceiver"
              }
            }
          }
        }
      ]
    }
  ],
  "accounts": [
    {
      "name": "BridgeConfig",
      "discriminator": [40, 206, 51, 233, 246, 40, 178, 85],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority",         "type": "pubkey" },
          { "name": "tokenMint",         "type": "pubkey" },
          { "name": "evmReceivers",      "type": { "vec": { "defined": { "name": "EvmChainReceiver" } } } },
          { "name": "totalBurned",       "type": "u64" },
          { "name": "totalMessagesSent", "type": "u64" },
          { "name": "bump",              "type": "u8" }
        ]
      }
    },
    {
      "name": "UserNonce",
      "discriminator": [235, 133, 1, 243, 18, 135, 88, 224],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "nonce", "type": "u64" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "EvmChainReceiver",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "chainId",         "type": "u16" },
          { "name": "receiverAddress", "type": { "array": ["u8", 20] } },
          { "name": "isActive",        "type": "bool" }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "BurnMessageEmitted",
      "discriminator": [31, 132, 141, 109, 6, 47, 154, 84],
      "fields": [
        { "name": "sequence",         "type": "u64" },
        { "name": "solanaMint",       "type": "pubkey" },
        { "name": "solanaSender",     "type": "pubkey" },
        { "name": "evmRecipient",     "type": { "array": ["u8", 20] } },
        { "name": "amountBurned",     "type": "u64" },
        { "name": "targetChainId",    "type": "u16" },
        { "name": "payloadHash",      "type": { "array": ["u8", 32] } },
        { "name": "consistencyLevel", "type": "u8" }
      ]
    }
  ],
  "errors": [
    { "code": 6000, "name": "BurnTooSmall",        "msg": "Burn amount too small. Minimum is 100 tokens to activate 1 chain." },
    { "code": 6001, "name": "InsufficientBalance",  "msg": "Insufficient token balance." },
    { "code": 6002, "name": "UnsupportedChain",     "msg": "Target chain not supported. Add it via update_receivers." },
    { "code": 6003, "name": "WrongMint",            "msg": "Token mint does not match bridge config." },
    { "code": 6004, "name": "WrongOwner",           "msg": "Token account owner does not match signer." },
    { "code": 6005, "name": "Unauthorized",         "msg": "Unauthorized: only the bridge authority can call this." },
    { "code": 6006, "name": "TooManyReceivers",     "msg": "Too many EVM receivers. Maximum is 10." }
  ]
}
