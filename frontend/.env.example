# Frontend – Environment Variables
# Copy this file to .env.local and fill in your values

# WalletConnect / RainbowKit project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# Alchemy API key for RPC access
NEXT_PUBLIC_ALCHEMY_KEY=your_alchemy_api_key

# ─── EVM TokenFactory addresses (fill after running deploy script) ──────────────
NEXT_PUBLIC_FACTORY_SEPOLIA=
NEXT_PUBLIC_FACTORY_BSC_TESTNET=
NEXT_PUBLIC_FACTORY_POLYGON_MUMBAI=
NEXT_PUBLIC_FACTORY_ARB_SEPOLIA=
NEXT_PUBLIC_FACTORY_BASE_SEPOLIA=
NEXT_PUBLIC_FACTORY_MAINNET=
NEXT_PUBLIC_FACTORY_BSC=
NEXT_PUBLIC_FACTORY_POLYGON=
NEXT_PUBLIC_FACTORY_ARBITRUM=
NEXT_PUBLIC_FACTORY_BASE=
NEXT_PUBLIC_FACTORY_AVALANCHE=

# ─── LPLocker addresses (fill after running deploy script) ───────────────────────
NEXT_PUBLIC_LOCKER_SEPOLIA=
NEXT_PUBLIC_LOCKER_BSC_TESTNET=
NEXT_PUBLIC_LOCKER_ARB_SEPOLIA=
NEXT_PUBLIC_LOCKER_BASE_SEPOLIA=
NEXT_PUBLIC_LOCKER_MAINNET=
NEXT_PUBLIC_LOCKER_BSC=
NEXT_PUBLIC_LOCKER_POLYGON=
NEXT_PUBLIC_LOCKER_ARBITRUM=
NEXT_PUBLIC_LOCKER_BASE=
NEXT_PUBLIC_LOCKER_AVALANCHE=

# ─── Cross-chain BurnBridgeReceiver addresses ────────────────────────────────────
# Fill after deploying BurnBridgeReceiver.sol on each EVM chain
NEXT_PUBLIC_RECEIVER_SEPOLIA=
NEXT_PUBLIC_RECEIVER_BSC_TESTNET=
NEXT_PUBLIC_RECEIVER_MAINNET=
NEXT_PUBLIC_RECEIVER_BSC=
NEXT_PUBLIC_RECEIVER_POLYGON=
NEXT_PUBLIC_RECEIVER_ARBITRUM=
NEXT_PUBLIC_RECEIVER_BASE=
NEXT_PUBLIC_RECEIVER_AVALANCHE=

# ─── Solana cross-chain bridge ───────────────────────────────────────────────────
# Program ID from `anchor build` in contracts/solana
NEXT_PUBLIC_SOLANA_BURN_BRIDGE_PROGRAM_ID=TokenBridgeBurnXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── AI Description Generator ────────────────────────────────────────────────
# OpenAI API key (optional – falls back to template descriptions)
OPENAI_API_KEY=

# ─── IPFS / Pinata ───────────────────────────────────────────────────────────
# Pinata JWT for IPFS uploads (optional – shows mock hash without it)
PINATA_JWT=

