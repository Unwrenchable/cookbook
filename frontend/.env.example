# Frontend – Environment Variables
# Copy this file to .env.local and fill in your values.
#
# For Vercel deployments, set these in:
#   Project Settings → Environment Variables
# Prefix NEXT_PUBLIC_ variables are exposed to the browser.
# Variables without that prefix are server-only (Next.js API routes).

# ── WalletConnect / RainbowKit ────────────────────────────────────────────────
# Get a project ID at https://cloud.walletconnect.com (free tier available)
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# ── Alchemy ───────────────────────────────────────────────────────────────────
# Used for all EVM chain RPCs. Get a key at https://alchemy.com
NEXT_PUBLIC_ALCHEMY_KEY=your_alchemy_api_key

# ── EVM TokenFactory addresses ────────────────────────────────────────────────
# Paste the `tokenFactory` address printed by `pnpm deploy:<network>`.
# Leave blank for chains you have not deployed to — the UI marks them
# as "not deployed" automatically.

# Testnets
NEXT_PUBLIC_FACTORY_SEPOLIA=
NEXT_PUBLIC_FACTORY_BSC_TESTNET=
NEXT_PUBLIC_FACTORY_POLYGON_AMOY=
NEXT_PUBLIC_FACTORY_ARB_SEPOLIA=
NEXT_PUBLIC_FACTORY_BASE_SEPOLIA=

# Mainnets
NEXT_PUBLIC_FACTORY_MAINNET=
NEXT_PUBLIC_FACTORY_BSC=
NEXT_PUBLIC_FACTORY_POLYGON=
NEXT_PUBLIC_FACTORY_ARBITRUM=
NEXT_PUBLIC_FACTORY_BASE=
NEXT_PUBLIC_FACTORY_AVALANCHE=

# ── LPLocker addresses ────────────────────────────────────────────────────────
# Paste the `lpLocker` address printed by `pnpm deploy:<network>`.

# Testnets
NEXT_PUBLIC_LOCKER_SEPOLIA=
NEXT_PUBLIC_LOCKER_BSC_TESTNET=
NEXT_PUBLIC_LOCKER_POLYGON_AMOY=
NEXT_PUBLIC_LOCKER_ARB_SEPOLIA=
NEXT_PUBLIC_LOCKER_BASE_SEPOLIA=

# Mainnets
NEXT_PUBLIC_LOCKER_MAINNET=
NEXT_PUBLIC_LOCKER_BSC=
NEXT_PUBLIC_LOCKER_POLYGON=
NEXT_PUBLIC_LOCKER_ARBITRUM=
NEXT_PUBLIC_LOCKER_BASE=
NEXT_PUBLIC_LOCKER_AVALANCHE=

# ── Cross-chain BurnBridgeReceiver addresses ──────────────────────────────────
# Paste the BurnBridgeReceiver address printed by `pnpm deploy:bridge:<network>`.
# Note: receiveMessage() is a scaffold and reverts until Wormhole VAA integration
# is complete. Use receiveRelayedMessage() + a trusted relayer for dev testing.

# Testnets
NEXT_PUBLIC_RECEIVER_SEPOLIA=
NEXT_PUBLIC_RECEIVER_BSC_TESTNET=
NEXT_PUBLIC_RECEIVER_POLYGON_AMOY=
NEXT_PUBLIC_RECEIVER_ARB_SEPOLIA=
NEXT_PUBLIC_RECEIVER_BASE_SEPOLIA=

# Mainnets
NEXT_PUBLIC_RECEIVER_MAINNET=
NEXT_PUBLIC_RECEIVER_BSC=
NEXT_PUBLIC_RECEIVER_POLYGON=
NEXT_PUBLIC_RECEIVER_ARBITRUM=
NEXT_PUBLIC_RECEIVER_BASE=
NEXT_PUBLIC_RECEIVER_AVALANCHE=

# ── Solana cross-chain bridge ─────────────────────────────────────────────────
# The program ID printed by `anchor deploy` in contracts/solana/.
NEXT_PUBLIC_SOLANA_BURN_BRIDGE_PROGRAM_ID=

# Optional: private Solana RPC (Alchemy/Helius/QuickNode).
# Falls back to public devnet/mainnet-beta endpoints.
NEXT_PUBLIC_SOLANA_RPC_URL=

# ── AI Description Generator ─────────────────────────────────────────────────
# Server-side only (no NEXT_PUBLIC_ prefix). Uses gpt-4o-mini via /api/ai-describe.
# Falls back to built-in template descriptions when not set.
OPENAI_API_KEY=

# ── IPFS / Pinata ────────────────────────────────────────────────────────────
# Server-side only. Used by /api/ipfs-upload to pin token logos + metadata.
# Falls back to deterministic mock hashes when not set.
PINATA_JWT=

