# ═══════════════════════════════════════════════════════════════════════════════
# GOONFORGE.XYZ – Frontend Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# LOCAL DEV  → Copy this file to .env.local and fill in your values.
#              Never commit .env.local — it is gitignored.
#
# VERCEL     → Set every variable in:
#                Project Settings → Environment Variables
#              Select which environments (Production / Preview / Development)
#              each variable applies to.  Use separate values for testnet
#              (Preview) and mainnet (Production) where applicable.
#
# SECURITY   → Variables prefixed NEXT_PUBLIC_ are embedded in the browser
#              bundle and visible to anyone.  Only non-sensitive config
#              (contract addresses, WalletConnect project ID) uses this prefix.
#              All API keys / RPC secrets are server-only (no NEXT_PUBLIC_).
#
# ── Legend ────────────────────────────────────────────────────────────────────
#   [PUBLIC]  Exposed to browser — keep non-sensitive
#   [SERVER]  Server-only (Next.js API routes / SSR) — keep secret
#   [REQUIRED] Must be set for full functionality
#   [OPTIONAL] Falls back to a safe default when not set
# ═══════════════════════════════════════════════════════════════════════════════


# ── WalletConnect / RainbowKit ────────────────────────────────────────────────
# [PUBLIC] [REQUIRED]
# Get a free project ID at https://cloud.walletconnect.com
# WalletConnect project IDs are designed to be public; they are domain-locked
# in the WalletConnect dashboard so third-party sites cannot use yours.
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id


# ── Alchemy – EVM RPC (SERVER-SIDE ONLY) ─────────────────────────────────────
# [SERVER] [REQUIRED for Alchemy-backed chains]
# Get a key at https://alchemy.com (free tier supports all listed chains).
# All EVM RPC calls are proxied through /api/rpc/[chainId] — this key NEVER
# reaches the browser bundle.
# Alchemy-backed chains: Ethereum, Polygon, Arbitrum, Base (mainnet + testnets).
# Public-RPC chains (BSC, Avalanche) do not use this key.
ALCHEMY_KEY=your_alchemy_api_key


# ── Solana RPC (SERVER-SIDE ONLY) ─────────────────────────────────────────────
# [SERVER] [OPTIONAL]
# Private Solana RPC from Alchemy (https://alchemy.com/solana),
# Helius (https://helius.dev), or QuickNode (https://quicknode.com).
# All Solana RPC calls are proxied through /api/solana-rpc — this URL NEVER
# reaches the browser bundle.
# Falls back to public Solana cluster endpoints when not set.
SOLANA_RPC_URL=


# ── Solana Burn-Bridge Program ────────────────────────────────────────────────
# [PUBLIC] [REQUIRED for Solana bridge]
# The program ID printed by `anchor deploy` in contracts/solana/.
# Testnet (devnet):  set on Vercel Preview environment
# Mainnet:           set on Vercel Production environment
NEXT_PUBLIC_SOLANA_BURN_BRIDGE_PROGRAM_ID=


# ── EVM TokenFactory contract addresses ───────────────────────────────────────
# [PUBLIC] [REQUIRED per chain]
# Paste the `tokenFactory` address printed by `pnpm deploy:<network>`.
# Leave blank for chains you have not deployed to — the UI flags them
# as "not deployed" automatically.
#
# ── Mainnets (set on Vercel Production environment) ──────────────
NEXT_PUBLIC_FACTORY_MAINNET=
NEXT_PUBLIC_FACTORY_BSC=
NEXT_PUBLIC_FACTORY_POLYGON=
NEXT_PUBLIC_FACTORY_ARBITRUM=
NEXT_PUBLIC_FACTORY_BASE=
NEXT_PUBLIC_FACTORY_AVALANCHE=
NEXT_PUBLIC_FACTORY_OPTIMISM=

# ── Testnets (set on Vercel Preview / Development environments) ──
NEXT_PUBLIC_FACTORY_SEPOLIA=
NEXT_PUBLIC_FACTORY_BSC_TESTNET=
NEXT_PUBLIC_FACTORY_POLYGON_AMOY=
NEXT_PUBLIC_FACTORY_ARB_SEPOLIA=
NEXT_PUBLIC_FACTORY_BASE_SEPOLIA=
NEXT_PUBLIC_FACTORY_OP_SEPOLIA=


# ── LPLocker contract addresses ───────────────────────────────────────────────
# [PUBLIC] [REQUIRED per chain]
# Paste the `lpLocker` address printed by `pnpm deploy:<network>`.
#
# ── Mainnets ──────────────────────────────────────────────────────
NEXT_PUBLIC_LOCKER_MAINNET=
NEXT_PUBLIC_LOCKER_BSC=
NEXT_PUBLIC_LOCKER_POLYGON=
NEXT_PUBLIC_LOCKER_ARBITRUM=
NEXT_PUBLIC_LOCKER_BASE=
NEXT_PUBLIC_LOCKER_AVALANCHE=
NEXT_PUBLIC_LOCKER_OPTIMISM=

# ── Testnets ─────────────────────────────────────────────────────
NEXT_PUBLIC_LOCKER_SEPOLIA=
NEXT_PUBLIC_LOCKER_BSC_TESTNET=
NEXT_PUBLIC_LOCKER_POLYGON_AMOY=
NEXT_PUBLIC_LOCKER_ARB_SEPOLIA=
NEXT_PUBLIC_LOCKER_BASE_SEPOLIA=
NEXT_PUBLIC_LOCKER_OP_SEPOLIA=


# ── Cross-chain BurnBridgeReceiver addresses ──────────────────────────────────
# [PUBLIC] [REQUIRED for cross-chain bridge]
# Paste the BurnBridgeReceiver address printed by `pnpm deploy:bridge:<network>`.
# Note: receiveMessage() reverts until the Wormhole VAA integration is complete.
# Use receiveRelayedMessage() + a trusted relayer for dev testing.
#
# ── Mainnets ──────────────────────────────────────────────────────
NEXT_PUBLIC_RECEIVER_MAINNET=
NEXT_PUBLIC_RECEIVER_BSC=
NEXT_PUBLIC_RECEIVER_POLYGON=
NEXT_PUBLIC_RECEIVER_ARBITRUM=
NEXT_PUBLIC_RECEIVER_BASE=
NEXT_PUBLIC_RECEIVER_AVALANCHE=
NEXT_PUBLIC_RECEIVER_OPTIMISM=

# ── Testnets ─────────────────────────────────────────────────────
NEXT_PUBLIC_RECEIVER_SEPOLIA=
NEXT_PUBLIC_RECEIVER_BSC_TESTNET=
NEXT_PUBLIC_RECEIVER_POLYGON_AMOY=
NEXT_PUBLIC_RECEIVER_ARB_SEPOLIA=
NEXT_PUBLIC_RECEIVER_BASE_SEPOLIA=
NEXT_PUBLIC_RECEIVER_OP_SEPOLIA=


# ── AI Description Generator ──────────────────────────────────────────────────
# [SERVER] [OPTIONAL]
# OpenAI API key used by /api/ai-describe (gpt-4o-mini model).
# Get a key at https://platform.openai.com/api-keys
# Falls back to built-in template descriptions when not set.
OPENAI_API_KEY=


# ── IPFS / Pinata ─────────────────────────────────────────────────────────────
# [SERVER] [OPTIONAL]
# Pinata JWT used by /api/ipfs-upload to pin token logos + metadata to IPFS.
# Get a JWT at https://app.pinata.cloud/developers/api-keys
# Falls back to deterministic mock hashes when not set (dev-friendly).
PINATA_JWT=

